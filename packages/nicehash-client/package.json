{
  "name": "@hashrate-autopilot/nicehash-client",
  "version": "0.1.0",
  "description": "Typed client for the NiceHash Hash-power marketplace REST API (HMAC-SHA256 signed)",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
